{
  "manifest_version": 3,
  "name": "Phishing Email Analyzer",
  "version": "1.0.0",
  "description": "Analyze suspicious emails or email-like pages for phishing indicators.",
    "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Phishing Email Analyzer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "analyzer.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
